# Copy this file to .env.local and fill in your real values:
#   cp .env.example .env.local
#
# .env.local is gitignored and must never be committed.

# Resend API key, used by the contact form (src/app/api/contact/route.ts).
# Get one at https://resend.com. Required for the contact form to send email.
RESEND_API_KEY=
